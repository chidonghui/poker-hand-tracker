/**app.wxss**/
page {
  --primary: #e94560;
  --primary-dark: #c73e54;
  --bg: #16213e;
  --card-bg: #1a1a2e;
  --surface: #0f3460;
  --text-primary: #ffffff;
  --text-secondary: #a0a0a0;
  --win: #4caf50;
  --loss: #f44336;
  --neutral: #9e9e9e;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: var(--bg);
  color: var(--text-primary);
}

.container {
  padding: 0 30rpx 40rpx;
  min-height: 100vh;
  background: var(--bg);
}

.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--surface);
}

.input-field {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 36rpx;
  color: var(--text-primary);
  font-family: 'Courier New', monospace;
  letter-spacing: 2rpx;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 50rpx;
  padding: 30rpx 60rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.win { color: var(--win); }
.loss { color: var(--loss); }
.neutral { color: var(--neutral); }

/* 扑克牌样式 */
.poker-card {
  width: 120rpx;
  height: 170rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
  position: relative;
}

.poker-card .rank {
  font-size: 48rpx;
  font-weight: bold;
  position: absolute;
  top: 10rpx;
  left: 15rpx;
}

.poker-card .suit {
  font-size: 72rpx;
}

.poker-card.red { color: #e53935; }
.poker-card.black { color: #212121; }

/* 花色 */
.suit-heart::before { content: '♥'; }
.suit-diamond::before { content: '♦'; }
.suit-spade::before { content: '♠'; }
.suit-club::before { content: '♣'; }

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: var(--text-secondary);
}

/* EV 相关样式 */
.ev-positive { color: #4caf50; }
.ev-negative { color: #f44336; }
.ev-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: rgba(233, 69, 96, 0.2);
  color: var(--primary);
}

.diff-positive {
  color: #4caf50;
}
.diff-negative {
  color: #f44336;
}
