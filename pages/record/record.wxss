/**pages/record/record.wxss**/
page {
  background: var(--bg);
}

.header {
  background: var(--card-bg);
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid var(--surface);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.input-section {
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 28rpx;
  color: var(--primary);
  margin-bottom: 16rpx;
  font-weight: 600;
}

.hand-input {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 40rpx;
  color: var(--text-primary);
  font-family: 'Courier New', monospace;
  letter-spacing: 4rpx;
  border: 2rpx solid transparent;
}

.hand-input:focus {
  border-color: var(--primary);
}

.input-hint {
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 12rpx;
}

.hint-title {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.hint-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 预览区 */
.preview-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.hand-preview {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.poker-card {
  width: 140rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.3);
  position: relative;
}

.poker-card .rank {
  position: absolute;
  top: 15rpx;
  left: 20rpx;
  font-size: 48rpx;
  font-weight: bold;
}

.poker-card .suit {
  font-size: 80rpx;
}

.poker-card.red { color: #e53935; }
.poker-card.black { color: #212121; }

.hand-info {
  text-align: center;
}

.hand-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 10rpx;
}

.amount {
  font-size: 56rpx;
  font-weight: 700;
}

/* 快捷按钮 */
.quick-buttons {
  margin-bottom: 40rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.quick-btn {
  flex: 1;
  background: var(--surface);
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.amount-btn {
  background: var(--primary);
  color: #fff;
}

.clear-btn {
  background: rgba(244, 67, 54, 0.2);
  color: #f44336;
}

/* 保存按钮 */
.save-btn {
  background: var(--primary);
  color: #fff;
  border-radius: 50rpx;
  padding: 30rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
}

.save-btn[disabled] {
  background: #555;
  color: #888;
}

.save-btn::after {
  border: none;
}

/* 今日统计 */
.today-stats {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--surface);
  border-radius: 12rpx;
  font-size: 28rpx;
}
