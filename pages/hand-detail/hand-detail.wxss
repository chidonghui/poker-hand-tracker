/**pages/hand-detail/hand-detail.wxss**/
page {
  background: var(--bg);
}

.header {
  background: var(--card-bg);
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid var(--surface);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.back {
  font-size: 28rpx;
  color: var(--primary);
}

.cards-display {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 40rpx 0;
}

.poker-card {
  width: 180rpx;
  height: 260rpx;
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.3);
  position: relative;
}

.poker-card.red { color: #e53935; }
.poker-card.black { color: #212121; }

.poker-card .rank {
  position: absolute;
  top: 20rpx;
  left: 25rpx;
  font-size: 64rpx;
  font-weight: bold;
}

.poker-card .suit {
  font-size: 100rpx;
}

/* 基本信息 */
.info-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--surface);
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-row .value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

/* 复盘信息 */
.review-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-group .label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

/* 公共牌输入 */
.community-cards-section {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 24rpx;
}

.community-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.community-row:last-child {
  margin-bottom: 0;
}

.street-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  width: 100rpx;
}

.card-input {
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 200rpx;
  text-transform: uppercase;
}

.card-input.single {
  width: 100rpx;
}

.parsed-cards {
  display: flex;
  gap: 12rpx;
}

.parsed-card {
  display: flex;
}

.mini-card {
  width: 60rpx;
  height: 84rpx;
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.mini-card.red { color: #e53935; }
.mini-card.black { color: #212121; }

.mini-rank {
  font-size: 24rpx;
  font-weight: bold;
}

.mini-suit {
  font-size: 28rpx;
}

/* 花色符号 */
.suit-spade::before { content: "♠"; }
.suit-heart::before { content: "♥"; }
.suit-club::before { content: "♣"; }
.suit-diamond::before { content: "♦"; }

/* 位置选择 */
.position-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pos-btn {
  background: var(--surface);
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.pos-btn.active {
  background: var(--primary);
  color: #fff;
}

/* 行动选择 */
.action-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  background: var(--surface);
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.action-btn.active {
  background: var(--primary);
  color: #fff;
}

/* EV 输入 */
.ev-input-group {
  display: flex;
  gap: 16rpx;
}

.ev-btn {
  background: var(--surface);
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  font-size: 36rpx;
  color: var(--text-primary);
}

.ev-input {
  flex: 1;
  background: var(--surface);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  text-align: center;
}

.hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  display: block;
}

/* 备注 */
.note-input {
  width: 100%;
  height: 200rpx;
  background: var(--surface);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* 按钮 */
.save-btn {
  background: var(--primary);
  color: #fff;
  border-radius: 50rpx;
  padding: 30rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.save-btn::after {
  border: none;
}

.delete-btn {
  background: rgba(244, 67, 54, 0.2);
  color: #f44336;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
}

.delete-btn::after {
  border: none;
}
